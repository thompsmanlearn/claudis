            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "body": "={{ $json.haiku_body }}",
        "options": {
          "timeout": 30000
        },
        "contentType": "raw"
      }
    },
    {
      "id": "n-build",
      "name": "Build Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        300
      ],
      "parameters": {
        "jsCode": "const m = $('Compute Behavioral Metrics').item.json;\nconst haiku = $json;\nlet analysis = 'Analysis unavailable';\ntry { analysis = haiku.content[0].text; } catch(e) {}\nconst today = new Date().toISOString().slice(0,10);\nconst expId = 'behavioral_health_' + m.agent_name + '_' + today;\nconst report = {agent_name: m.agent_name, display_name: m.display_name, workflow_id: m.workflow_id, registry_status: m.status, test_type: 'behavioral_health_check', test_source: 'SpecOps-inspired: real n8n execution log analysis', metrics: {exec_count: m.exec_count, success_count: m.success_count, error_count: m.error_count, success_rate: m.success_rate, avg_duration_ms: m.avg_duration_ms, error_streak: m.error_streak, consistency_score: m.consistency_score}, metrics_summary: m.metrics_summary, behavioral_analysis: analysis, evaluated_at: new Date().toISOString()};\nreturn [{json: {experiment_id: expId, report: report, analysis_text: analysis, agent_name: m.agent_name, metrics_summary: m.metrics_summary}}];"
      }
    },
