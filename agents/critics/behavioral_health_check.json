      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "=http://host.docker.internal:5678/api/v1/executions?workflowId={{$('Get Agent Registry').item.json.workflow_id}}&limit=10",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
