re 0-10, whether errors are systematic, recommendation (promote/retire/investigate/monitor). Under 100 words.';\n  metricsOut = {agent_name: agentData.agent_name||'unknown', display_name: agentData.display_name, workflow_id: agentData.workflow_id, status: agentData.status, exec_count: execList.length, success_count: successes.length, error_count: errors.length, success_rate: Math.round(successRate*100)/100, avg_duration_ms: avgDuration, error_streak: errorStreak, consistency_score: Math.round(consistency*100)/100, metrics_summary: summary};\n}\nconst haikuBody = JSON.stringify({model: 'claude-haiku-4-5', max_tokens: 200, messages: [{role: 'user', content: promptText}]});\nreturn [{json: Object.assign({}, metricsOut, {haiku_body: haikuBody})}];"
