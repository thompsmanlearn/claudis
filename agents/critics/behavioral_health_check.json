    {
      "id": "n-compute",
      "name": "Compute Behavioral Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ],
      "parameters": {
        "jsCode": "const agentData = $('Get Agent Registry').item.json;\nconst execData = $json;\nconst execList = Array.isArray(execData) ? execData : (execData.data || []);\nlet promptText;\nlet metricsOut;\nif (execList.length === 0) {\n  promptText = 'Agent ' + JSON.stringify(agentData.agent_name||'unknown') + ' has no execution history. Status: ' + (agentData.status||'unknown') + '. Reliability score 0-10 for untested agent, recommendation (promote/retire/investigate/monitor). Under 80 words.';\n  metricsOut = {agent_name: agentData.agent_name||'unknown', display_name: agentData.display_name, workflow_id: agentData.workflow_id, status: agentData.status, exec_count: 0, success_count: 0, error_count: 0, success_rate: null, avg_duration_ms: null, error_streak: 0, consistency_score: null, metrics_summary: 'No execution history.'};\n} else {\n  const successes = execList.filter(e => e.status === 'success');\n  const errors = execList.filter(e => e.status === 'error');\n  const successRate = successes.length / execList.length;\n  const durations = execList.filter(e => e.startedAt && e.stoppedAt).map(e => new Date(e.stoppedAt)-new Date(e.startedAt));\n  const avgDuration = durations.length > 0 ? Math.round(durations.reduce((a,b)=>a+b,0)/durations.length) : null;\n  let errorStreak = 0;\n  for (let i=0; i<execList.length; i++) { if (execList[i].status==='error') errorStreak++; else break; }\n  const consistency = (successRate===1.0||successRate===0.0) ? 1.0 : 1.0-(2*successRate*(1-successRate));\n  const summary = execList.length+' execs: '+successes.length+' ok/'+errors.length+' err. '+Math.round(successRate*100)+'% success. Avg '+(avgDuration||'N/A')+'ms. Streak: '+errorStreak+'.';\n  promptText = 'Evaluate AADP agent ' + JSON.stringify(agentData.agent_name) + '. Last '+execList.length+' runs: '+successes.length+' success, '+errors.length+' error. Rate: '+Math.round(successRate*100)+'%. Avg: '+(avgDuration||'N/A')+'ms. Error streak: '+errorStreak+'. Reliability score 0-10, whether errors are systematic, recommendation (promote/retire/investigate/monitor). Under 100 words.';\n  metricsOut = {agent_name: agentData.agent_name||'unknown', display_name: agentData.display_name, workflow_id: agentData.workflow_id, status: agentData.status, exec_count: execList.length, success_count: successes.length, error_count: errors.length, success_rate: Math.round(successRate*100)/100, avg_duration_ms: avgDuration, error_streak: errorStreak, consistency_score: Math.round(consistency*100)/100, metrics_summary: summary};\n}\nconst haikuBody = JSON.stringify({model: 'claude-haiku-4-5', max_tokens: 200, messages: [{role: 'user', content: promptText}]});\nreturn [{json: Object.assign({}, metricsOut, {haiku_body: haikuBody})}];"
      }
    },
    {
      "id": "n-haiku",
      "name": "Haiku Analysis",
