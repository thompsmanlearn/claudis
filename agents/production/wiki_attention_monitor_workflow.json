        "id": "node-detect-spikes",
        "name": "Detect Spikes",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1080,
          380
        ],
        "parameters": {
          "jsCode": "const prev=$input.all();let wikiResp=null;const configRows=[];for(const item of prev){  if(item.json&&item.json.items&&Array.isArray(item.json.items)){wikiResp=item.json;}  else if(item.json&&item.json.config_key){configRows.push(item.json);}}if(!wikiResp){return[{json:{error:'Missing wiki data',spikes:[],focus_hits:[],all_pages:[]}}];}if(configRows.length===0){return[{json:{error:'Missing config data',spikes:[],focus_hits:[],all_pages:[]}}];}const cfgMap={};for(const row of configRows){cfgMap[row.config_key]=row.config_value;}const focusTopics=(cfgMap.focus_topics||[]).map(function(t){return t.toLowerCase();});const ignoreTopics=(cfgMap.ignore_topics||[]).map(function(t){return t.toLowerCase();});const SPIKE_VIEW_THRESHOLD=50000;const spikes=[];const focus_hits=[];const all_pages=[];const articles=wikiResp.items[0].articles||[];for(let i=0;i<articles.length;i++){  const page=articles[i];const title=page.article||'';  const views=page.views||0;const rank=page.rank||i+1;  const titleLower=title.toLowerCase().replace(/_/g,' ');  let skip=false;  for(const ig of ignoreTopics){if(titleLower.indexOf(ig)>=0){skip=true;break;}}  if(skip)continue;  if(titleLower==='main page'||titleLower==='special:search')continue;  const displayTitle=title.replace(/_/g,' ');  const pageObj={title:displayTitle,views:views,rank:rank};  if(all_pages.length<1000)all_pages.push(pageObj);  let isFocus=false;  for(const ft of focusTopics){if(titleLower.indexOf(ft)>=0){isFocus=true;break;}}  if(isFocus&&views>10000)focus_hits.push(pageObj);  if(views>=SPIKE_VIEW_THRESHOLD&&!isFocus)spikes.push(pageObj);}spikes.sort(function(a,b){return b.views-a.views;});focus_hits.sort(function(a,b){return b.views-a.views;});return[{json:{spikes:spikes.slice(0,20),focus_hits:focus_hits.slice(0,20),all_pages:all_pages.slice(0,200),config:cfgMap,date_label:''}}];",
          "mode": "runOnceForAllItems"
        }
      },
