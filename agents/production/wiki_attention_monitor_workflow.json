      {
        "id": "node-format-report",
        "name": "Format Report",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1920,
          380
        ],
        "parameters": {
          "jsCode": "const d=$input.all();let spikeData=null,haikuResp=null,dateLabel='';for(const item of d){if(item.json&&item.json.spikes!==undefined)spikeData=item.json;if(item.json&&item.json.content&&Array.isArray(item.json.content))haikuResp=item.json;}const spikes=(spikeData&&spikeData.spikes)||[];const focus_hits=(spikeData&&spikeData.focus_hits)||[];const all_pages=(spikeData&&spikeData.all_pages)||[];const today=new Date();today.setDate(today.getDate()-1);const yr=today.getFullYear();const mo=String(today.getMonth()+1).padStart(2,'0');const dy=String(today.getDate()).padStart(2,'0');dateLabel=yr+'-'+mo+'-'+dy;let clusterText='';if(haikuResp&&haikuResp.content&&haikuResp.content[0]){const raw=haikuResp.content[0].text||'';const stripped=raw.replace(/```json\\s*/g,'').replace(/```\\s*/g,'').trim();let parsed=false;const startIdx=stripped.indexOf('[');const endIdx=stripped.lastIndexOf(']');if(startIdx>=0&&endIdx>startIdx){try{const clusters=JSON.parse(stripped.slice(startIdx,endIdx+1));clusterText=clusters.slice(0,3).map(function(c){return '\\u2022 '+c.name+' ('+c.pages.length+' pages)';}).join('\\n');parsed=true;}catch(e){}}if(!parsed)clusterText=stripped.replace(/[{}\"\\[\\]]/g,'').slice(0,200);}if(!clusterText)clusterText='(no clusters)';const emergingLines=spikes.slice(0,5).map(function(p){const k=Math.round(p.views/1000);return '\\u2022 '+p.title+' \\u2014 '+k+'k views';}).join('\\n')||'\\u2022 (none above threshold)';const focusLines=focus_hits.slice(0,8).map(function(p){const k=Math.round(p.views/1000);return '\\u2022 '+p.title+' \\u2014 '+k+'k views';}).join('\\n')||'\\u2022 (no focus topics trending)';const totalAnalyzed=all_pages.length;const spikeCount=spikes.length;const report_text='\\ud83d\\udce1 Wiki Attention Monitor \\u2014 '+dateLabel+'\\n\\n\\ud83d\\udd25 EMERGING\\n'+emergingLines+'\\n\\n\\ud83d\\udc41 FOCUS TOPICS\\n'+focusLines+'\\n\\n\\ud83c\\udf10 STORY CLUSTERS\\n'+clusterText+'\\n\\n'+totalAnalyzed+' pages analyzed \\u00b7 '+spikeCount+' notable \\u00b7 /wiki for details';const nowStr=new Date().toISOString().slice(0,10);const lastReport=(spikeData&&spikeData.config&&spikeData.config.last_report_date)||'';const already_sent=typeof lastReport==='string'&&lastReport.startsWith(nowStr);return[{json:{report_text:report_text,spikes:spikes,focus_hits:focus_hits,all_pages:all_pages,already_sent:already_sent,date_label:dateLabel,spikes_count:spikes.length,focus_hits_count:focus_hits.length}}];",
          "mode": "runOnceForAllItems"
        }
      },
