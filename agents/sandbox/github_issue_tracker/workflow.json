              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ agent_name: 'github_issue_tracker', experiment_id: 'scan_' + new Date().toISOString().slice(0,10), output_type: 'issue_scan', content: $('Filter Stale Issues').item.json, confidence: 1.0, promoted: false, reviewed_by_bill: false }) }}"
      }
    },
