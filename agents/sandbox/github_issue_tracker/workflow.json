      }
    },
    {
      "id": "fetch_issues",
      "name": "Fetch GitHub Issues",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        220,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/thompsmanlearn/claudis/issues",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "state",
              "value": "open"
            },
            {
              "name": "per_page",
              "value": "50"
            },
            {
              "name": "sort",
              "value": "updated"
            },
            {
              "name": "direction",
              "value": "asc"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "{{CREDENTIAL_REDACTED}}"
            },
            {
              "name": "Accept",
              "value": "application/vnd.github.v3+json"
            },
            {
              "name": "User-Agent",
              "value": "AADP-Claudis/1.0"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "filter_stale",
      "name": "Filter Stale Issues",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        0
      ],
      "parameters": {
        "jsCode": "const issues = $input.all();\nconst now = new Date();\nconst THREE_DAYS_MS = 3 * 24 * 60 * 60 * 1000;\n\nlet allIssues = [];\nfor (const item of issues) {\n  const data = item.json;\n  if (Array.isArray(data)) {\n    allIssues = allIssues.concat(data);\n  } else if (data && data.number) {\n    allIssues.push(data);\n  }\n}\n\nconst openIssues = allIssues.filter(i => !i.pull_request);\nconst stale = openIssues.filter(issue => {\n  const updated = new Date(issue.updated_at);\n  return (now - updated) > THREE_DAYS_MS;\n});\n\nconst total_open = openIssues.length;\n\nif (stale.length === 0) {\n  return [{ json: { stale_count: 0, total_open, stale_issues: [], message: `\u2705 GitHub issues: ${total_open} open, all active (updated <3d).` } }];\n}\n\nconst formatted = stale.map(issue => {\n  const updated = new Date(issue.updated_at);\n  const days_stale = Math.floor((now - updated) / (24 * 60 * 60 * 1000));\n  return {\n    number: issue.number,\n    title: issue.title,\n    url: issue.html_url,\n    days_stale,\n    labels: (issue.labels || []).map(l => l.name).join(', ')\n  };\n});\n\nconst lines = [`\u26a0\ufe0f ${stale.length} stale GitHub issue${stale.length > 1 ? 's' : ''} (>3d no activity):`];\nfor (const i of formatted) {\n  lines.push(`#${i.number} (${i.days_stale}d) \u2014 ${i.title.slice(0,55)}`);\n  lines.push(`  ${i.url}`);\n}\nlines.push(`\\nTotal open: ${total_open}`);\n\nreturn [{ json: { stale_count: stale.length, total_open, stale_issues: formatted, message: lines.join('\\n') } }];"
      }
    },
    {
      "id": "send_telegram",
      "name": "Send Telegram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        660,
        0
      ],
      "parameters": {
