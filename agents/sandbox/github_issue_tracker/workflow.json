        "url": "http://localhost:5678/webhook/telegram-quick-send",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({chat_id: 8513796837, message: $json.message}) }}",
        "options": {}
      }
    },
