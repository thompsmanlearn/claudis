    {
      "parameters": {
        "url": "https://cihbfubghytzqrpffgcq.supabase.co/rest/v1/work_queue?status=in.(pending,claimed)&select=id,task_type",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "{{SUPABASE_SERVICE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "Bearer {{SUPABASE_SERVICE_KEY}}"
            }
          ]
        },
        "options": {}
      },
      "id": "fetch_wq",
      "name": "Fetch Work Queue",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        224,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst all = [];\nfor (const item of items) {\n  if (Array.isArray(item.json)) all.push(...item.json);\n  else if (item.json && item.json.id) all.push(item.json);\n}\nif (all.length === 0) return [{ json: { wq_count: 0, wq_types: 'none', wq_raw: [] } }];\nconst types = {};\nfor (const t of all) { types[t.task_type] = (types[t.task_type] || 0) + 1; }\nconst summary = Object.entries(types).map(([k,v]) => v > 1 ? v+'x'+k : k).join(', ');\nreturn [{ json: { wq_count: all.length, wq_types: summary, wq_raw: all } }];",
        "mode": "runOnceForAllItems"
      },
      "id": "parse_wq",
      "name": "Parse Work Queue",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://cihbfubghytzqrpffgcq.supabase.co/rest/v1/agent_registry?select=status",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "{{SUPABASE_SERVICE_KEY}}"
            },
            {
              "name": "Authorization",
