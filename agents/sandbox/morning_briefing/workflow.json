      "id": "fetch_registry",
      "name": "Fetch Agent Registry",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        672,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst all = [];\nfor (const item of items) {\n  if (Array.isArray(item.json)) all.push(...item.json);\n  else if (item.json && item.json.status) all.push(item.json);\n}\nconst counts = { active: 0, sandbox: 0, paused: 0, retired: 0 };\nfor (const a of all) {\n  if (a.status in counts) counts[a.status]++;\n  else counts.retired++;\n}\nreturn [{ json: { agent_counts: counts } }];",
        "mode": "runOnceForAllItems"
      },
      "id": "parse_registry",
      "name": "Parse Agent Registry",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        0
      ]
    },
    {
      "parameters": {
        "url": "http://localhost:9100/stats",
        "options": {}
