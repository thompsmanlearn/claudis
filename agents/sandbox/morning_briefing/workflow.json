      "id": "fetch_sys",
      "name": "Fetch System Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1120,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "url": "https://cihbfubghytzqrpffgcq.supabase.co/rest/v1/experimental_outputs?created_at=gte={{ new Date(Date.now()-86400000).toISOString() }}&select=id",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "{{SUPABASE_SERVICE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "Bearer {{SUPABASE_SERVICE_KEY}}"
            }
          ]
        },
        "options": {}
      },
      "id": "fetch_outputs_24h",
      "name": "Fetch 24h Outputs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1344,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const today = new Date().toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric', timeZone:'America/Los_Angeles' });\nconst wq = $('Parse Work Queue').item.json;\nconst agents = $('Parse Agent Registry').item.json.agent_counts;\nlet sysStr = 'unavailable';\ntry {\n  const sys = $('Fetch System Status').item.json;\n  if (sys && sys.cpu_percent !== undefined) {\n    sysStr = 'CPU ' + sys.cpu_percent + '%, RAM ' + sys.memory_percent + '%, Disk ' + sys.disk_percent + '%, Temp ' + sys.temperature_c + 'C';\n  }\n} catch(e) {}\nlet outputCount = 0;\ntry {\n  const outItems = $('Fetch 24h Outputs').all();\n  for (const item of outItems) {\n    if (Array.isArray(item.json)) outputCount += item.json.length;\n    else if (item.json && item.json.id) outputCount++;\n  }\n} catch(e) {}\nconst wqLine = wq.wq_count === 0 ? 'Work queue: empty' : 'Work queue: ' + wq.wq_count + ' pending (' + wq.wq_types + ')';\nconst agentLine = 'Agents: ' + agents.active + ' active, ' + agents.sandbox + ' sandbox, ' + agents.paused + ' paused';\nconst sysLine = 'System: ' + sysStr;\nconst outputLine = 'Last 24h: ' + outputCount + ' new experimental outputs';\nconst healthStatus = (agents.active >= 6) ? 'AADP is healthy.' : 'Check agent status.';\nconst message = 'Good morning Bill - ' + today + '\\n\\n' + wqLine + '\\n' + agentLine + '\\n' + sysLine + '\\n' + outputLine + '\\n\\n' + healthStatus;\nreturn [{ json: { message, today, wq_count: wq.wq_count, agent_counts: agents, output_count: outputCount } }];",
        "mode": "runOnceForAllItems"
      },
      "id": "build_message",
      "name": "Build Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1568,
        0
      ]
    },
